# ---------------------------------------------------------------------------
# Copy this file to ".env" for LOCAL testing only.
# In production (GitHub Actions) these values MUST come from GitHub Secrets.
# Never commit a real .env file with real values.
# ---------------------------------------------------------------------------

# ---- REQUIRED (secrets) ----
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFatherReplaceMe
TELEGRAM_CHAT_ID=123456789

# ---- OPTIONAL OVERRIDES (safe defaults are already built into the code) ----

# CROUS campaign tool id fallback (used only if homepage auto-detection fails).
# CROUS_FALLBACK_TOOL_ID=41

# Ile-de-France bounding box (two opposite corners).
# CROUS_BBOX_WEST=1.4461
# CROUS_BBOX_SOUTH=48.1201
# CROUS_BBOX_EAST=3.5590
# CROUS_BBOX_NORTH=49.2412

# Search paging.
# CROUS_PAGE_SIZE=50
# CROUS_MAX_PAGES=40

# HTTP timeouts / retries (CROUS requests).
# HTTP_CONNECT_TIMEOUT=10
# HTTP_READ_TIMEOUT=30
# HTTP_MAX_RETRIES=4
# HTTP_BACKOFF_BASE=2.0

# Telegram retries.
# TELEGRAM_MAX_RETRIES=5
# TELEGRAM_BACKOFF_BASE=2.0

# Monitoring behaviour.
# FAILURE_THRESHOLD=3
# HEARTBEAT_INTERVAL_HOURS=24
